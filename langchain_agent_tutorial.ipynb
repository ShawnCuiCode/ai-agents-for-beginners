    "from langchain_anthropic import ChatAnthropic\n",
    "from langchain_classic.agents import create_react_agent, AgentExecutor\n",
    "from langchain_core.tools import tool\n",
    "from langchain_core.prompts import PromptTemplate\n",
    "from langchain_core.messages import HumanMessage, AIMessage\n",
    "import math\n",
    "import datetime\n",
    "\n",
    "# react-chat 妯℃澘锛堝惈 chat_history锛屼笌 Cell 18 涓€鑷达級\n",
    "_REACT_CHAT_TEMPLATE = \"\"\"Assistant is a large language model.\n",
    "\n",
    "Assistant has access to the following tools:\n",
    "\n",
    "{tools}\n",
    "\n",
    "To use a tool, use the following format:\n",
    "\n",
    "Thought: Do I need to use a tool? Yes\n",
    "Action: the action to take, should be one of [{tool_names}]\n",
    "Action Input: the input to the action\n",
    "Observation: the result of the action\n",
    "\n",
    "When you have a response to the Human, or do not need a tool, use:\n",
    "\n",
    "Thought: Do I need to use a tool? No\n",
    "Final Answer: [your response here]\n",
    "\n",
    "Begin!\n",
    "\n",
    "Previous conversation history:\n",
    "{chat_history}\n",
    "\n",
    "New input: {input}\n",
    "{agent_scratchpad}\"\"\"\n",
    "\n",
    "\n",
    "class AgentService:\n",
    "    \"\"\"灏佽 LangChain + Claude Agent 鐨勬湇鍔＄被\"\"\"\n",
    "\n",
    "    def __init__(self, model: str = \"claude-sonnet-4-5\", verbose: bool = False):\n",
    "        self.llm = ChatAnthropic(\n",
    "            model=model,\n",
    "            temperature=0,\n",
    "            max_tokens=4096,\n",
    "        )\n",
    "        self.tools = self._build_tools()\n",
    "        self.chat_history = []\n",
    "        self.executor = self._build_executor(verbose=verbose)\n",
    "\n",
    "    def _build_tools(self):\n",
    "        \"\"\"鏋勫缓宸ュ叿鍒楄〃锛堝彲鍦ㄦ鎵╁睍鏇村宸ュ叿锛塡"\"\"\n",
    "\n",
    "        @tool\n",
    "        def calculator(expression: str) -> str:\n",
    "            \"\"\"璁＄畻鏁板琛ㄨ揪寮忥紝鏀寔 math 妯″潡鍑芥暟锛屼緥濡?'math.sqrt(16)'銆俓"\"\"\n",
    "            try:\n",
    "                allowed = {k: v for k, v in math.__dict__.items() if not k.startswith('_')}\n",
    "                return str(eval(expression, {\"__builtins__\": {}}, allowed))\n",
    "            except Exception as e:\n",
    "                return f\"璁＄畻鍑洪敊: {e}\"\n",
    "\n",
    "        @tool\n",
    "        def get_current_time(format: str = \"%Y-%m-%d %H:%M:%S\") -> str:\n",
    "            \"\"\"鑾峰彇褰撳墠鏃ユ湡鍜屾椂闂淬€俓"\"\"\n",
    "            return datetime.datetime.now().strftime(format)\n",
    "\n",
    "        return [calculator, get_current_time]\n",
    "\n",
    "    def _build_executor(self, verbose: bool) -> AgentExecutor:\n",
    "        \"\"\"鏋勫缓 AgentExecutor\"\"\"\n",
    "        prompt = PromptTemplate.from_template(_REACT_CHAT_TEMPLATE)\n",
    "        agent = create_react_agent(llm=self.llm, tools=self.tools, prompt=prompt)\n",
    "        return AgentExecutor(\n",
    "            agent=agent,\n",
    "            tools=self.tools,\n",
    "            verbose=verbose,\n",
    "            max_iterations=10,\n",
    "            handle_parsing_errors=True,\n",
    "        )\n",
    "\n",
    "    def chat(self, user_input: str) -> str:\n",
    "        \"\"\"鍙戦€佹秷鎭紝鑷姩缁存姢瀵硅瘽鍘嗗彶\"\"\"\n",
    "        result = self.executor.invoke({\n",
    "            \"input\": user_input,\n",
    "            \"chat_history\": self.chat_history,\n",
    "        })\n",
    "        output = result[\"output\"]\n",
    "        self.chat_history.append(HumanMessage(content=user_input))\n",
    "        self.chat_history.append(AIMessage(content=output))\n",
    "        return output\n",
    "\n",
    "    def reset(self):\n",
    "        \"\"\"娓呯┖瀵硅瘽鍘嗗彶\"\"\"\n",
    "        self.chat_history = []\n",
    "        print(\"鉁?瀵硅瘽鍘嗗彶宸叉竻绌篭")\n",
    "\n",
    "\n",
    "# ---- 浣跨敤绀轰緥 ----\n",
    "service = AgentService(model=\"claude-sonnet-4-5\", verbose=True)\n",
    "\n",
    "answer1 = service.chat(\"璁＄畻 sin(30搴? 鐨勫€硷紝娉ㄦ剰 math.sin 鎺ュ彈寮у害\")\n",
    "print(f\"\\n鍥炵瓟: {answer1}\\n\")\n",
    "\n",
    "answer2 = service.chat(\"鐜板湪鏄嚑鏈堝嚑鏃ワ紵\")\n",
    "print(f\"\\n鍥炵瓟: {answer2}\")\n"
   ]
  },
