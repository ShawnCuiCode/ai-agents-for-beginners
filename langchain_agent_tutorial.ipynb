    "        saving = f\"  鑺傜渷{100*(base_tokens-tok)//base_tokens}%\" if tok < base_tokens else \"\"\n",
    "        print(f\"  {name:<20} ~{tok:>4} tokens  {bar}{saving}  {note}\")\n",
