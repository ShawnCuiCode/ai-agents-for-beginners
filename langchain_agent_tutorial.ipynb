   "source": [
    "from langgraph.graph import StateGraph, END\n",
    "from langchain_core.messages import HumanMessage\n",
    "from typing import TypedDict, List, Annotated\n",
    "import operator, time\n",
    "\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "#  1. 瀹氫箟鍏变韩鐘舵€侊紙姣忎釜鑺傜偣璇诲啓鍚屼竴涓?State锛塡n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "class RAGState(TypedDict):\n",
    "    query:          str           # 鐢ㄦ埛闂\n",
    "    cache_hit:      bool          # 鏄惁鍛戒腑缂撳瓨\n",
    "    retrieved_docs: List          # 鍚戦噺鍙洖缁撴灉\n",
    "    reranked_docs:  List          # 绮炬帓鍚庣殑鏂囨。\n",
    "    answer:         str           # 鏈€缁堢瓟妗圽n",
    "    token_log:      List[str]     # 鍚勮妭鐐?Token 娑堣€楄褰昞n",
    "\n",
    "# 绠€鍗曞唴瀛樼紦瀛橈紙鐢熶骇鐜鍙崲 Redis锛塡n",
    "_rag_cache: dict = {}\n",
    "\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "#  2. 鑺傜偣鍑芥暟锛堟瘡涓妭鐐?= 涓€涓?Python 鍑芥暟锛塡n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "\n",
    "def node_cache_check(state: RAGState) -> dict:\n",
    "    \"\"\"妫€鏌ョ紦瀛橈細鍛戒腑鍒欑洿鎺ョ煭璺紝璺宠繃鍚庣画鎵€鏈夎妭鐐筡"\"\"\n",
    "    q = state[\"query\"]\n",
    "    if q in _rag_cache:\n",
    "        print(f\"  [cache_check] 鈿?鍛戒腑缂撳瓨锛岃烦杩囨绱?鐢熸垚\")\n",
    "        return {\"cache_hit\": True, \"answer\": _rag_cache[q], \"token_log\": [\"cache_check: 0 tokens锛堝懡涓紦瀛橈級\"]}\n",
    "    print(f\"  [cache_check] 鏈懡涓紝杩涘叆妫€绱㈡祦绋媆")\n",
    "    return {\"cache_hit\": False, \"token_log\": [\"cache_check: 0 tokens锛堟湭鍛戒腑锛塡"]}\n",
    "\n",
    "def node_retrieve(state: RAGState) -> dict:\n",
    "    \"\"\"鍚戦噺鍙洖锛氱敤 Chroma 妫€绱?k=6 鍊欓€夊潡\"\"\"\n",
    "    docs = chroma_db.similarity_search(state[\"query\"], k=6)\n",
    "    tok  = sum(estimate_tokens(d.page_content) for d in docs)\n",
    "    print(f\"  [retrieve]    鍙洖 {len(docs)} 鍧楋紝鍚堣 ~{tok} tokens\")\n",
    "    return {\"retrieved_docs\": docs,\n",
    "            \"token_log\": state.get(\"token_log\", []) + [f\"retrieve: ~{tok} tokens锛堝彫鍥瀧len(docs)}鍧楋級\"]}\n",
    "\n",
    "def node_rerank(state: RAGState) -> dict:\n",
    "    \"\"\"Cross-Encoder 绮炬帓锛氫粠鍙洖缁撴灉涓€夋渶鐩稿叧鐨?top-2\"\"\"\n",
    "    docs  = state[\"retrieved_docs\"]\n",
    "    pairs = [(state[\"query\"], d.page_content) for d in docs]\n",
    "    scores = reranker.predict(pairs)\n",
    "    ranked = sorted(zip(scores, docs), key=lambda x: x[0], reverse=True)\n",
    "    top2   = [d for _, d in ranked[:2]]\n",
    "    tok    = sum(estimate_tokens(d.page_content) for d in top2)\n",
    "    print(f\"  [rerank]      绮炬帓鍚庝繚鐣?{len(top2)} 鍧楋紝鍚堣 ~{tok} tokens  (鑺傜渷 {len(docs)-len(top2)} 鍧?\")\n",
    "    return {\"reranked_docs\": top2,\n",
    "            \"token_log\": state.get(\"token_log\", []) + [f\"rerank: ~{tok} tokens锛堢簿鎺掍繚鐣檣len(top2)}鍧楋級\"]}\n",
    "\n",
    "def node_generate(state: RAGState) -> dict:\n",
    "    \"\"\"LLM 鐢熸垚锛氱敤绮炬帓鏂囨。浣滀负 Context 鐢熸垚鏈€缁堢瓟妗圽"\"\"\n",
    "    context = \"\\n---\\n\".join([d.page_content[:400] for d in state[\"reranked_docs\"]])\n",
    "    prompt  = (\n",
    "        f\"Answer the question using ONLY the context below. Be concise.\\n\\n\"\n",
    "        f\"Context:\\n{context}\\n\\n\"\n",
    "        f\"Question: {state['query']}\"\n",
    "    )\n",
    "    ctx_tokens = estimate_tokens(context)\n",
    "    answer = llm.invoke([HumanMessage(content=prompt)]).content\n",
    "    print(f\"  [generate]    Context ~{ctx_tokens} tokens 鈫?鐢熸垚瀹屾瘯\")\n",
    "    # 鍐欏叆缂撳瓨\n",
    "    _rag_cache[state[\"query\"]] = answer\n",
    "    return {\"answer\": answer,\n",
    "            \"token_log\": state.get(\"token_log\", []) + [f\"generate: context ~{ctx_tokens} tokens\"]}\n",
    "\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "#  3. 鏉′欢璺敱鍑芥暟\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "def route_after_cache(state: RAGState) -> str:\n",
    "    return \"END\" if state[\"cache_hit\"] else \"retrieve\"\n",
    "\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "#  4. 鏋勫缓 StateGraph\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "builder = StateGraph(RAGState)\n",
    "\n",
    "# 娉ㄥ唽鑺傜偣\n",
    "builder.add_node(\"cache_check\", node_cache_check)\n",
    "builder.add_node(\"retrieve\",    node_retrieve)\n",
    "builder.add_node(\"rerank\",      node_rerank)\n",
    "builder.add_node(\"generate\",    node_generate)\n",
    "\n",
    "# 鍏ュ彛\n",
    "builder.set_entry_point(\"cache_check\")\n",
    "\n",
    "# 鏉′欢杈癸細cache_check 鈫?END锛堝懡涓級or retrieve锛堟湭鍛戒腑锛塡n",
    "builder.add_conditional_edges(\n",
    "    \"cache_check\",\n",
    "    route_after_cache,\n",
    "    {\"END\": END, \"retrieve\": \"retrieve\"},\n",
    ")\n",
    "\n",
    "# 鍥哄畾杈筡n",
    "builder.add_edge(\"retrieve\", \"rerank\")\n",
    "builder.add_edge(\"rerank\",   \"generate\")\n",
    "builder.add_edge(\"generate\", END)\n",
    "\n",
    "# 缂栬瘧涓哄彲鎵ц鍥綷n",
    "rag_graph = builder.compile()\n",
    "print(\"鉁?LangGraph RAG 娴佹按绾挎瀯寤哄畬鎴怽")\n",
    "print()\n",
    "\n",
    "# 鈹€鈹€ 鎵撳嵃鍥剧粨鏋勶紙ASCII锛夆攢鈹€\n",
    "try:\n",
    "    print(rag_graph.get_graph().draw_ascii())\n",
    "except Exception:\n",
    "    print(\"  cache_check 鈫?retrieve 鈫?rerank 鈫?generate 鈫?END\")\n",
    "    print(\"  cache_check 鈫?END锛堝懡涓紦瀛樻椂锛塡")"
   ]
  },
