    "    #  宸ュ叿 2锛氭暟瀛﹁绠梊n",
    "    # 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€\n",
    "    @mcp.tool()\n",
    "    def calculate(expression: str) -> str:\n",
    "        \"\"\"璁＄畻鏁板琛ㄨ揪寮忥紝鏀寔 math 妯″潡鍑芥暟锛屼緥濡?math.sqrt(16)銆俓"\"\"\n",
    "        try:\n",
    "            allowed = {{k: v for k, v in math.__dict__.items() if not k.startswith(\"_\")}}\n",
    "            return str(eval(expression, {{\"__builtins__\": {{}}}}, allowed))\n",
    "        except Exception as e:\n",
    "            return f\"璁＄畻鍑洪敊: {{e}}\"\n",
    "\n",
    "    # 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€\n",
    "    #  鍚姩 Server锛坰tdio 妯″紡锛屼緵 Claude Desktop / VS Code 璋冪敤锛塡n",
    "    # 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€\n",
