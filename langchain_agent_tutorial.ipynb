      "\n",
      "馃敡 宸ュ叿鍚? get_current_time\n",
      "   鎻忚堪: 鑾峰彇褰撳墠鐨勬棩鏈熷拰鏃堕棿銆傚彲閫夊弬鏁?format 鎸囧畾鏃堕棿鏍煎紡锛岄粯璁や负 '%Y-%m-%d %H:%M:%S'銆?..\n",
      "\n",
      "馃敡 宸ュ叿鍚? text_processor\n",
      "   鎻忚堪: 瀵规枃鏈墽琛屽鐞嗘搷浣溿€俓n",
      "浼犲叆鏍煎紡涓?\"鎿嶄綔绫诲瀷|瑕佸鐞嗙殑鏂囨湰\"锛岀敤绔栫嚎 | 鍒嗛殧銆俓n",
      "渚嬪: \"word_count|Hello LangChain Agent\" ...\n",
      "\n"
     ]
    }
   ],
   "source": [
    "from langchain_core.tools import tool\n",
    "import math\n",
    "import datetime\n",
    "\n",
    "# ----- 宸ュ叿 1锛氳绠楀櫒 -----\n",
    "@tool\n",
    "def calculator(expression: str) -> str:\n",
    "    \"\"\"璁＄畻鏁板琛ㄨ揪寮忋€傝緭鍏ュ簲涓哄悎娉曠殑 Python 鏁板琛ㄨ揪寮忥紝渚嬪 '2 + 3 * 4' 鎴?'math.sqrt(16)'銆俓n",
    "    鏀寔鍔犲噺涔橀櫎銆佸箓杩愮畻銆乵ath 妯″潡涓殑鍑芥暟銆俓"\"\"\n",
    "    try:\n",
    "        # 闄愬埗鍙敤鐨勫懡鍚嶇┖闂达紝閬垮厤鎵ц鍗遍櫓浠ｇ爜\n",
    "        allowed_names = {k: v for k, v in math.__dict__.items() if not k.startswith('_')}\n",
    "        result = eval(expression, {\"__builtins__\": {}}, allowed_names)\n",
    "        return str(result)\n",
    "    except Exception as e:\n",
    "        return f\"璁＄畻鍑洪敊: {e}\"\n",
    "\n",
    "# ----- 宸ュ叿 2锛氳幏鍙栧綋鍓嶆椂闂?-----\n",
    "@tool\n",
    "def get_current_time(format: str = \"%Y-%m-%d %H:%M:%S\") -> str:\n",
    "    \"\"\"鑾峰彇褰撳墠鐨勬棩鏈熷拰鏃堕棿銆傚彲閫夊弬鏁?format 鎸囧畾鏃堕棿鏍煎紡锛岄粯璁や负 '%Y-%m-%d %H:%M:%S'銆俓"\"\"\n",
    "    return datetime.datetime.now().strftime(format)\n",
    "\n",
    "# ----- 宸ュ叿 3锛氬瓧绗︿覆澶勭悊 -----\n",
    "@tool\n",
    "def text_processor(request: str) -> str:\n",
    "    \"\"\"瀵规枃鏈墽琛屽鐞嗘搷浣溿€俓n",
    "    浼犲叆鏍煎紡涓?\"鎿嶄綔绫诲瀷|瑕佸鐞嗙殑鏂囨湰\"锛岀敤绔栫嚎 | 鍒嗛殧銆俓n",
    "    渚嬪: \"word_count|Hello LangChain Agent\" 鎴?\"upper|hello world\"\n",
    "    鏀寔鐨勬搷浣? upper锛堣浆澶у啓锛夈€乴ower锛堣浆灏忓啓锛夈€乺everse锛堝弽杞級銆乴ength锛堣绠楅暱搴︼級銆亀ord_count锛堢粺璁¤瘝鏁帮級\n",
    "    \"\"\"\n",
    "    if \"|\" not in request:\n",
    "        return \"鏍煎紡閿欒锛岃浣跨敤: 鎿嶄綔绫诲瀷|鏂囨湰锛屼緥濡? word_count|Hello LangChain Agent\"\n",
    "    operation, text = request.split(\"|\", 1)\n",
    "    operation = operation.strip()\n",
    "    text = text.strip()\n",
    "    ops = {\n",
    "        \"upper\": lambda t: t.upper(),\n",
    "        \"lower\": lambda t: t.lower(),\n",
    "        \"reverse\": lambda t: t[::-1],\n",
    "        \"length\": lambda t: str(len(t)),\n",
    "        \"word_count\": lambda t: str(len(t.split())),\n",
    "    }\n",
    "    if operation not in ops:\n",
    "        return f\"涓嶆敮鎸佺殑鎿嶄綔: {operation}锛屽彲鐢ㄦ搷浣? {list(ops.keys())}\"\n",
    "    return ops[operation](text)\n",
    "\n",
    "# 灏嗗伐鍏锋斁鍏ュ垪琛╘n",
    "tools = [calculator, get_current_time, text_processor]\n",
    "\n",
    "# 鏌ョ湅宸ュ叿淇℃伅\n",
    "for t in tools:\n",
    "    print(f\"馃敡 宸ュ叿鍚? {t.name}\")\n",
    "    print(f\"   鎻忚堪: {t.description[:80]}...\")\n",
    "    print()\n"
   ]
  },
