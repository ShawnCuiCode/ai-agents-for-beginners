    "@functools.lru_cache(maxsize=128)\n",
    "def cached_search(query: str) -> str:\n",
    "    \"\"\"甯︾紦瀛樼殑鐭ヨ瘑搴撴绱細鐩稿悓闂鐩存帴杩斿洖缂撳瓨锛岄伩鍏嶉噸澶?API 璋冪敤\"\"\"\n",
