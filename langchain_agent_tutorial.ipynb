    "print(\"  鍘熺悊锛氭妸涓嶅彉鐨?system prompt / 闀挎枃妗ｆ斁鍦ㄨ姹傛渶鍓嶉潰骞跺姞 cache_control\")\n",
    "print(\"  鏁堟灉锛歝ache read token 璐圭巼 鈮?鍘熻垂鐜?1/10锛宑ache write 涓哄師璐圭巼 1.25x\")\n",
    "print(\"  閫傜敤鍦烘櫙锛氬杞璇濄€佸悓涓€鏂囨。鍙嶅闂瓟锛堝鏁存湰涔?RAG锛塡")\n",
    "print(\"  瀹炵幇鏂瑰紡锛氬湪 ChatAnthropic 涓缃?model_kwargs={'extra_headers': ...}\")\n",
    "print(\"            鎴栦娇鐢?anthropic SDK 鐩存帴鎺у埗 content block 鐨?cache_control\")\n",
    "\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "#  缁煎悎瀵规瘮锛堝惈鏂版柟娉曪級\n",
    "# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲\n",
    "print(f\"\\n{'鈺?*60}\")\n",
    "print(\"  鍏ㄩ儴鏂规硶 Token 瀵规瘮姹囨€籠")\n",
    "print(f\"{'鈺?*60}\")\n",
    "\n",
    "for name, tok, note in [\n",
    "    (\"鍩哄噯 k=3\",              base_tokens,   \"\"),\n",
    "    (\"鏂规硶1 闃堝€艰繃婊",         filt_tokens,   \"鉂楅槇鍊奸渶璋冨弬\"),\n",
    "    (\"鏂规硶2 MMR 鍘婚噸\",         mmr_tokens,    \"猸愭棤棰濆璐圭敤\"),\n",
    "    (\"鏂规硶3 Compression\",     comp_tokens,   \"闇€1娆LM璋冪敤\"),\n",
    "    (\"鏂规硶4 Cross-Encoder\",   rerank_tokens, \"猸愨瓙鏃犻澶栬垂鐢紝绮惧害鏈€楂榎"),\n",
    "    (\"鏂规硶5 HyDE\",            hyde_tokens,   \"闇€1娆LM璋冪敤\"),\n",
