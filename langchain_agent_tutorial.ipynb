    "print(f\"{'#':<4} {'ID':<26} {'Topic':<12} 鍐呭棰勮\")\n",
    "print(\"鈹€\" * 80)\n",
    "for i, (doc_id, doc, meta) in enumerate(zip(ids, documents, metadatas)):\n",
