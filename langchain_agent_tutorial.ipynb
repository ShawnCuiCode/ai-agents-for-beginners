    "\n",
    "    # 鈹€鈹€ 鍒濆鍖栵紙鍚姩鏃跺姞杞戒竴娆★級鈹€鈹€\n",
    "    _embeddings = HuggingFaceEmbeddings(model_name=\"all-MiniLM-L6-v2\")\n",
