    "    鐢ㄦ硶: python mcp_server.py\n",
    "    \"\"\"\n",
    "    import math\n",
    "    from mcp.server.fastmcp import FastMCP\n",
    "    from langchain_huggingface import HuggingFaceEmbeddings\n",
